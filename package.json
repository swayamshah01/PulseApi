{
  "name": "pulseapi",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "test": "npm run test --workspace backend",
    "build": "npm run build --workspace frontend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:deploy": "npm run prisma:deploy --workspace backend",
    "prisma:validate": "npm run prisma:validate --workspace backend",
    "prisma:status": "npm run prisma:status --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MonitorStatus {
  ACTIVE
  PAUSED
}

enum ErrorType {
  TIMEOUT
  DNS
  NETWORK
  SSL
  INVALID_STATUS
  BLOCKED_URL
  UNKNOWN
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  email         String         @unique
  passwordHash  String
  refreshTokens RefreshToken[]
  projects      Project[]
  monitors      Monitor[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Project {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  monitors    Monitor[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, name])
  @@index([userId, updatedAt(sort: Desc)])
}

model Monitor {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @db.Uuid
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId           String        @db.Uuid
  project             Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                String
  url                 String
  method              String        @default("GET")
  expectedStatusCode  Int           @default(200)
  timeoutMs           Int           @default(5000)
  intervalSeconds     Int           @default(300)
  status              MonitorStatus @default(ACTIVE)
  isUp                Boolean?
  lastStatusCode      Int?
  lastResponseTimeMs  Int?
  lastCheckedAt       DateTime?
  nextCheckAt         DateTime?
  consecutiveFailures Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  checkResults        CheckResult[]

  @@index([userId])
  @@index([projectId])
  @@index([status, nextCheckAt])
}

model CheckResult {
  id                BigInt     @id @default(autoincrement())
  monitorId         String     @db.Uuid
  monitor           Monitor    @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  checkedAt         DateTime
  success           Boolean
  statusCode        Int?
  responseTimeMs    Int
  errorType         ErrorType?
  errorMessage      String?
  responseSizeBytes Int?
  createdAt         DateTime   @default(now())

  @@index([monitorId, checkedAt(sort: Desc)])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}
